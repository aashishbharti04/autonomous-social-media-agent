# ─────────────────────────────────────────────────────────────
# Autonomous Social Media Agent — environment configuration
# Copy this file to `.env` and fill in values to enable live mode.
# With NO keys set, every external service runs in MOCK mode and
# the full multi-agent pipeline still works offline (great for demos).
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=4000
NODE_ENV=development

# --- LLM provider (Content & SEO agents) ---
# Provider options: "mock" (default, no key needed) | "anthropic" | "openai"
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Image agent ---
# "mock" (default) | "openai" (DALL·E / gpt-image) | "stability"
IMAGE_PROVIDER=mock
STABILITY_API_KEY=

# --- Vector memory (RAG) ---
# "memory" (default in-process store) | "chroma"
VECTOR_PROVIDER=memory
CHROMA_URL=http://localhost:8000

# --- Database ---
# "memory" (default in-process store) | "postgres"
DB_PROVIDER=memory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asma

# --- Social publishing (Publishing agent) ---
# Leave blank to publish in MOCK mode (returns fake post IDs).
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
