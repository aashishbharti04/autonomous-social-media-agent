# ─────────────────────────────────────────────────────────────
# Autonomous Social Media Agent — environment configuration
# Copy this file to `.env` and fill in values to enable live mode.
# With NO keys set, every external service runs in MOCK mode and
# the full multi-agent pipeline still works offline (great for demos).
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=4000
NODE_ENV=development

# --- LLM provider (Content & SEO agents) ---
# Provider options: "mock" (default, no key needed) | "anthropic" | "openai"
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Image agent ---
# "mock" (default) | "openai" (DALL·E / gpt-image) | "stability"
IMAGE_PROVIDER=mock
STABILITY_API_KEY=

# --- Vector memory (RAG) ---
# "memory" (default in-process store) | "chroma"
VECTOR_PROVIDER=memory
CHROMA_URL=http://localhost:8000

# --- Database ---
# "memory" (default in-process store, resets on restart) | "postgres"
# For postgres, set DB_PROVIDER=postgres and a connection string (e.g. from
# Neon / Supabase / Render). The backend auto-creates its tables on startup.
DB_PROVIDER=memory
DATABASE_URL=

# --- Auth ---
# Secret used to sign login (JWT) tokens. MUST be set to a long random string
# in production. A dev fallback is used if empty.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Scheduler ---
# How often (ms) the background scheduler checks for due scheduled posts.
SCHEDULER_INTERVAL_MS=30000

# --- Email (verification & password reset) ---
# Frontend URL used to build verify/reset links.
APP_BASE_URL=http://localhost:3000
# Optional: set a Resend API key to actually send emails. Without it, links are
# logged to the server console (fully usable for local dev / demos).
RESEND_API_KEY=
EMAIL_FROM=Autonomous Social Media Agent <onboarding@resend.dev>

# --- Social publishing (Publishing agent) ---
# Leave blank to publish in MOCK mode (returns fake post IDs).
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
